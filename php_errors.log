<?php
session_start();
require_once 'db.php';

// Enable error reporting for debugging
error_reporting(E_ALL);
ini_set('display_errors', 1);

// Redirect to login if not authenticated
if (!isset($_SESSION['user_id'])) {
    header("Location: login.php");
    exit();
}

$message = '';
$error = '';

// Handle form submission
if ($_SERVER['REQUEST_METHOD'] == 'POST') {

    $caption = trim($_POST['caption'] ?? '');
    $location = trim($_POST['location'] ?? '');
    $user_id = $_SESSION['user_id'];

    // Validation
    if (empty($caption)) {
        $error = "Please write a caption";
    } elseif (!isset($_FILES['image']) || $_FILES['image']['error'] != 0) {
        $error = "Please select an image";
    } else {
        // Validate file type
        $allowed_types = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
        $finfo = finfo_open(FILEINFO_MIME_TYPE);
        $mime_type = finfo_file($finfo, $_FILES['image']['tmp_name']);
        finfo_close($finfo);

        if (!in_array($mime_type, $allowed_types)) {
            $error = "Invalid file type. Only JPG, PNG, GIF, WEBP allowed.";
        } elseif ($_FILES['image']['size'] > 10 * 1024 * 1024) {
            $error = "File too large. Max 10MB allowed.";
        } else {
            // File upload
            $target_dir = "uploads/";
            if (!is_dir($target_dir)) {
                mkdir($target_dir, 0777, true);
            }

            $file_extension = pathinfo($_FILES["image"]["name"], PATHINFO_EXTENSION);
            $file_name = time() . "_" . uniqid() . "." . strtolower($file_extension);
            $target_file = $target_dir . $file_name;

            // Move uploaded file
            if (move_uploaded_file($_FILES["image"]["tmp_name"], $target_file)) {
                // Insert post into database
                $stmt = $conn->prepare("INSERT INTO posts (user_id, caption, image, location, created_at) VALUES (?, ?, ?, ?, NOW())");
                $stmt->bind_param("isss", $user_id, $caption, $target_file, $location);

                if ($stmt->execute()) {
                    $new_post_id = $stmt->insert_id;
                    $stmt->close();

                    // Update user post count
                    $update_stmt = $conn->prepare("UPDATE users SET posts_count = posts_count + 1 WHERE id = ?");
                    $update_stmt->bind_param("i", $user_id);
                    $update_stmt->execute();
                    $update_stmt->close();

                    header("Location: index.php?uploaded=1&id=" . $new_post_id);
                    exit();
                } else {
                    unlink($target_file);
                    $error = "Database error: " . $stmt->error;
                }
            } else {
                $error = "Failed to upload image";
            }
        }
    }
}
